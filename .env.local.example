# Copy this file to .env.local and fill in your values
# Prefer using MONGODB_URI directly. If set, split Mongo vars can stay empty.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=
MONGODB_URI=
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_CLUSTER=
MONGODB_DATABASE=
